#!/usr/bin/perl

# Copyright 2002-2026, Paul Johnson (paul@pjcj.net)

# This software is free.  It is licensed under the same terms as Perl itself.

# The latest version of this software should be available from my homepage:
# https://pjcj.net

use 5.42.0;

# VERSION

use Devel::Cover::Collection ();

use Cwd          qw( abs_path cwd );
use Getopt::Long qw( GetOptions );
use Pod::Usage   qw( pod2usage );

# use Carp; $SIG{__DIE__} = \&Carp::confess;

$|++;

my $Options = {
  bin_dir               => abs_path($0) =~ s|/cpancover$||r,
  build                 => 1,
  compress_old_versions => 0,
  docker                => "docker",
  dryrun                => 0,
  force                 => 0,
  generate_html         => 0,
  latest                => 0,
  local                 => 0,
  local_build           => 0,
  mark_rebuilt          => 0,
  modules               => [],
  output_file           => "index.html",
  rebuild               => 0,
  rebuild_batch         => 100,
  report                => "html",
  results_dir           => cwd(),
  timeout               => undef,
  verbose               => 0,
  workers               => 0,
};

sub get_options {
  #<<<
  die "Bad option" unless GetOptions(
    $Options, qw(
      bin_dir=s
      build!
      compress_old_versions=i
      docker=s
      dryrun!
      env=s
      force!
      generate_html!
      help|h!
      info|i!
      latest!
      local!
      local_build!
      mark_rebuilt!
      module_file=s
      modules=s
      output_file=s
      rebuild!
      rebuild_batch=i
      report=s
      results_dir=s
      timeout=i
      verbose!
      version|v!
      workers=i
    )
  );
  #>>>

  say "$0 version " . __PACKAGE__->VERSION and exit 0 if $Options->{version};
  pod2usage(-exitval => 0, -verbose => 0) if $Options->{help};
  pod2usage(-exitval => 0, -verbose => 2) if $Options->{info};
}

sub newcp {
  #<<<
  Devel::Cover::Collection->new(
    map { $_ => $Options->{$_} } qw(
      bin_dir
      docker
      dryrun
      env
      force
      local
      mark_rebuilt
      modules
      output_file
      rebuild
      rebuild_batch
      report
      results_dir
      timeout
      verbose
      workers
    )
  )
  #>>>
}

sub main {
  # TODO - only one instance should run at a time
  get_options;
  # say Dumper($Options) if $Options->{verbose};

  if ($Options->{latest}) {
    my $cp = newcp;
    $cp->get_latest;
    return;
  }

  if ($Options->{local_build}) {
    my $cp = newcp;
    $cp->set_modules(@ARGV);
    $cp->local_build;
    return;
  }

  my %counts;

  if ($Options->{module_file}) {
    my $cp = newcp;
    $cp->set_module_file($Options->{module_file});
    $counts{new_count} += $cp->cover_modules;
  }

  if ($Options->{build}) {
    my $cp;
    if (@ARGV) {
      $cp = newcp;
      $cp->set_modules(@ARGV);
    } elsif (!-t STDIN) {
      my @modules;
      while (my $l = <>) {
        chomp $l;
        push @modules, split " ", $l;
      }
      $cp = newcp;
      $cp->set_modules(@modules);
    } else {
      $cp = newcp;
    }
    $counts{new_count} += $cp->cover_modules;
  }

  if ($Options->{rebuild}) {
    my $cp = newcp;
    $counts{rebuilt_count} = $cp->rebuild_pass if $Options->{rebuild_batch};
    $counts{all_rebuilt}   = $cp->all_rebuilt ? 1 : 0;
    $cp->write_status(%counts);
  } elsif ($Options->{mark_rebuilt}) {
    my $cp = newcp;
    $cp->write_status(%counts);
  }

  if ($Options->{generate_html}) {
    my $cp = newcp;
    $cp->generate_html;
  }

  if ($Options->{compress_old_versions}) {
    my $cp = newcp;
    $cp->compress_old_versions($Options->{compress_old_versions});
  }
}

main

__END__

=encoding utf8

=head1 NAME

cpancover - report coverage statistics on CPAN modules

=head1 SYNOPSIS

  cpancover --help --info --version
            --build --generate_html --rebuild --rebuild_batch n
            --mark_rebuilt
            --latest --local --local_build
            --modules module_name --module_file file
            --results_dir /path/to/dir --output_file filename.html
            --report report_name
            --compress_old_versions number_to_keep
            --force --dryrun --verbose
            --workers n --timeout seconds
            --bin_dir /path --docker command --env name

=head1 DESCRIPTION

=head1 OPTIONS

The following command line options are supported:

  -h --help               - show help
  -i --info               - show documentation
  -v --version            - show version

  --bin_dir               - location of the cover binaries     ($0 dir)
  --build                 - collect coverage from modules       (on)
  --compress_old_versions - compress data older than n versions (0)
  --docker                - docker command to use               (docker)
  --dryrun                - don't execute (for some commands)   (off)
  --env                   - collection environment              (prod)
  --force                 - recollect coverage                  (off)
  --generate_html         - generate html                       (off)
  --latest                - process latest CPAN releases        (off)
  --local                 - use local (uninstalled) code        (off)
  --local_build           - build coverage for all the modules  (off)
  --mark_rebuilt          - mark built modules as rebuilt       (off)
  --module_file           - read module list from a file        (none)
  --modules               - modules to use                (all in results_dir)
  --output_file           - top level index                     (index.html)
  --rebuild               - rebuild already-covered modules      (off)
  --rebuild_batch         - how many distdirs per rebuild pass   (100)
  --report                - report to use                        (html)
  --results_dir           - where to store output               ($cwd)
  --timeout               - per-distribution timeout in seconds  (3600)
  --verbose               - verbose output                       (off)
  --workers               - number of parallel workers           (0)

=head1 DETAILS

=head1 REQUIREMENTS

Collect coverage for results and create html, csv and json output.

The modules L<Template> and L<Parallel::Iterator> are required.

=head1 EXIT STATUS

The following exit values are returned:

=over

=item 0

All operations were completed successfully.

=item >0

An error occurred.

=back

=head1 SEE ALSO

L<Devel::Cover>

