# Demonstrates the asymmetry MC/DC was invented to catch.  This is the
# four-test worked example from docs/technical/mcdc.md: the decision
# `($is_owner && $unlocked) || $is_admin` exercised with four inputs.
# Those inputs achieve 100% statement, branch, and condition coverage
# (every row of both the outer `or_3` and inner `and_3` truth tables is
# observed) but $unlocked has no short-circuit-aware independence
# pair, so MC/DC drops to 66.6%.  Adding a fifth test `(T,F,F)` would
# take MC/DC to 100% and catch the misplaced-negation bug shown in
# the design doc that the four-test condition-coverage set hides.
#
# This fixture exists to lock in that asymmetry as a permanent
# regression test.  If a future change to the analyser ever makes
# MC/DC track condition coverage exactly, this fixture's golden file
# will diverge and force the question to be answered.

use strict;
use warnings;

sub may_edit {
  my ($is_owner, $unlocked, $is_admin) = @_;
  return ($is_owner && $unlocked) || $is_admin;
}

sub main {
  my @r;

  # The four-test set from docs/technical/mcdc.md "Tests achieving 100%
  # statement, branch, and condition coverage".  Hits every row of both
  # the outer `or_3` and inner `and_3` truth tables, but leaves
  # $is_owner and $unlocked without independence pairs.
  push @r, may_edit(1, 1, 1);
  push @r, may_edit(1, 0, 1);
  push @r, may_edit(0, 0, 1);
  push @r, may_edit(0, 0, 0);
}

main();
