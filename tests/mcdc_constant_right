use strict;
use warnings;

sub and_const_true {
  my ($p) = @_;
  return $p && 1;
}

sub or_const_false {
  my ($p) = @_;
  return $p || 0;
}

sub main {
  # Calls are pushed into @r so each decision is exercised in non-void
  # context; MC/DC for a void-context boolean has no result to analyse.
  my @r;

  # Constant on the right of && and ||. The constant operand is never an
  # independence-pair candidate (it cannot vary), so the analyser must
  # handle it without trying to find a pair.
  push @r, and_const_true(1);
  push @r, and_const_true(0);
  push @r, or_const_false(1);
  push @r, or_const_false(0);
}

main();
