# Subroutine signatures (introduced experimentally in 5.20.0) compile to
# extra logops in the optree prologue for argument-count handling.  This
# fixture exercises MC/DC through subs declared with signatures so the
# per-CV walker is exercised against an optree that mixes signature
# logops with user logops.  The walker must isolate the two: signature
# ops are their own roots, and the user's decision metadata (root,
# width, column indices) must not be perturbed.

use 5.20.0;
use warnings;
use feature qw( signatures );
no warnings qw( experimental::signatures );

sub and_decision ($p, $q)         { $p && $q }
sub or_decision  ($p, $q)         { $p         || $q }
sub nested       ($a, $b, $c, $d) { ($a && $b) || ($c && $d) }

sub main {
  my @r;

  # 2-input && hits all three short-circuit rows.
  push @r, and_decision(1, 1);
  push @r, and_decision(1, 0);
  push @r, and_decision(0, 1);

  # 2-input || hits all three short-circuit rows.
  push @r, or_decision(1, 0);
  push @r, or_decision(0, 1);
  push @r, or_decision(0, 0);

  # Mixed-precedence ($a && $b) || ($c && $d).  The statement-level outer ||
  # is recorded as a branch but its decision structure is kept, so MC/DC
  # measures the unified four-condition decision.  Called for its value, the
  # decision's input vectors are observed, so MC/DC is proven (these four calls
  # achieve it partially).  The per-CV walk stays clear of signature ops.
  push @r, nested(1, 1, 0, 0);
  push @r, nested(1, 0, 1, 1);
  push @r, nested(0, 0, 1, 0);
  push @r, nested(0, 0, 0, 0);
}

main();
