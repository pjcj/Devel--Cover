use strict;
use warnings;

# A // whose right operand is an always-defined variable: neither atomic
# condition's independence pair can be formed, so the whole decision is
# uncoverable for MC/DC.  A bare marker covers every column.
sub dor_default {
  my ($h, $k, $val) = @_;
  # uncoverable mcdc
  return $h->{$k} //= $val;
}

# $a && $b where the left operand is always true: its pair can never be formed,
# but the right operand's can.  pair:1 marks only the left column.
sub left_always_true {
  my ($b) = @_;
  my $always = 1;
  # uncoverable mcdc pair:1
  return $always && $b;
}

# $a && $b && $c is a compound decision, parsed ($a && $b) && $c.  $b is held
# true, so the inner $a && !$b outcome - the row $b's MC/DC independence pair
# needs - can never occur.  The plain condition marker on that inner outcome
# (count:2 selects the inner $a && $b) now also excuses $b for MC/DC, derived
# from the compound truth table with no separate "# uncoverable mcdc" needed.
sub compound_inner {
  my ($a, $c) = @_;
  my $b = 1;
  # uncoverable condition right count:2
  return $a && $b && $c;
}

sub main {
  # Push results so each decision runs in non-void context.
  my @r;
  my %h;
  push @r, dor_default(\%h, "a", 1);  # left undef  -> assigns
  push @r, dor_default(\%h, "a", 1);  # left defined -> skips
  push @r, left_always_true(1);
  push @r, left_always_true(0);
  push @r, compound_inner(0, 0);  # a false
  push @r, compound_inner(1, 0);  # a true, c false
  push @r, compound_inner(1, 1);  # all true
}

main();
