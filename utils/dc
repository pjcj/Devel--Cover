install_perl() {
  local name="${1:?No name specified}"
  local version="${2:?No version specified}"
  yes | plenv uninstall "$name" || true
  plenv install --as "$name" -j 32 -D usedevel --noman "$version"
  export PLENV_VERSION="$name"
  plenv install-cpanm
  install_dependencies
}

