  get_cpm
  pi "Installing dependencies with $cpm"
  $cpm install --workers="$(nice_cpus)" --global \
    Sereal Digest::MD5 Template Pod::Coverage::CountParents \
    Capture::Tiny Parallel::Iterator Template Class::XSAccessor
}

