#!/bin/bash

# . ./utils/setup

# shellcheck disable=SC3037
tidy() { echo -n "$1" | perl -naF: -e'print join ":", grep !$s{$_}++&&-e, @F'; }
dc_home=$PWD
PATH=$(tidy "$dc_home/utils:$PATH")
export PATH

# shellcheck disable=SC2034,SC2207,SC3030,SC3043
if [[ -n "$ZSH_VERSION" ]]; then
  _dc() {
    local -a o
    o=($(utils/dc options))
    _describe 'dc command' o
  }
  _build() {
    local -a o
    o=($(docker/BUILD options))
    _describe 'build command' o
  }
  compdef _dc dc
  compdef _build BUILD
fi
