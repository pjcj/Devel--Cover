9                                              
10                                             # Coverage of code required from other files.  The top-level statements of
11                                             # each module run inside the eval CV the require creates, and perl frees
12                                             # that op tree as soon as the require completes.  Devel::Cover keeps the
13                                             # tree alive from its leaveeval hook and walks it at report time, so the
14                                             # module's top-level statements, branches, conditions and subs are covered.
15                                             # Each module here exercises a different part of that machinery:
16                                             #   Module_top_level     - top-level statements, branches and nested anon subs
17                                             #   Module_lexical_sub    - a my sub reached through its prototype CV (5.22+)
18                                             #   Module_line_directive - a final statement under a #line naming another file
19                                             #   Module_enclosing_sub  - subs that enclose a my sub (introcv/clonecv prologue)
20                                             
21             1                           1   use strict;
               1                               
               1                               
22             1                           1   use warnings;
               1                               
               1                               
23                                             
24             1                           1   use lib "tests";
               1                               
               1                               
25                                             
26             1                           1   use Module_top_level;
               1                               
               1                               
27             1                           1   use Module_lexical_sub;
               1                               
               1                               
28             1                           1   use Module_line_directive;
               1                               
               1                               
29             1                           1   use Module_enclosing_sub;
               1                               
               1                               
30                                             
31             1                               print "count: ",      Module_top_level::get_count(),      "\n";
32             1                               print "add: ",        Module_top_level::add(),            "\n";
33             1                               print "run_outer: ",  Module_top_level::run_outer(),      "\n";
34             1                               print "run_begin: ",  Module_top_level::run_begin(),      "\n";
35                                             
36             1                               print "get: ",        Module_lexical_sub::get(),          "\n";
37                                             
