23                                             sub dor_const_href {
24             2                           2     my ($x) = @_;
25             2           100    100            return $x // {};
26                                             }
27                                             
28                                             sub main {
29                                               # Calls are pushed into @r so each decision is exercised in non-void
30                                               # context; MC/DC for a void-context boolean has no result to analyse.
31             1                           1     my @r;
32                                             
33                                               # Constant on the right of && and ||. The constant operand is never an
34                                               # independence-pair candidate (it cannot vary), so the analyser must
35                                               # handle it without trying to find a pair.
36             1                                 push @r, and_const_true(1);
37             1                                 push @r, and_const_true(0);
38             1                                 push @r, or_const_false(1);
39             1                                 push @r, or_const_false(0);
40                                             
41                                               # Reference constant on the right of //. The runtime can record an
42                                               # observed input vector wider than the collapsed boolean table (the
43                                               # uncollapsed {} keeps its column on some perls), so MC/DC must still
44                                               # credit the left operand once both outcomes are exercised.
45             1                                 push @r, dor_const_href(undef);
46             1                                 push @r, dor_const_href(1);
47                                             }
48                                             
49             1                               main();


