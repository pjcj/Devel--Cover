9                                              
10                                             # The top-level statements in Module_top_level.pm run inside the eval CV
11                                             # created by the require, and perl frees that op tree as soon as the
12                                             # require completes.  Devel::Cover keeps the tree alive from its
13                                             # leaveeval hook and walks it at report time, so the module's top-level
14                                             # statements, branches and conditions are covered.  Anon subs keep
15                                             # their prototype CVs in the pad of the CV enclosing them, so a
16                                             # recursive pad walk from the eval CV finds them at any depth.
17                                             
18             1                           1   use strict;
               1                               
               1                               
19             1                           1   use warnings;
               1                               
               1                               
20                                             
21             1                           1   use lib "tests";
               1                               
               1                               
22                                             
23             1                           1   use Module_top_level;
               1                               
               1                               
24                                             
25             1                               print "count: ",     Module_top_level::get_count(), "\n";
26             1                               print "add: ",       Module_top_level::add(),       "\n";
27             1                               print "run_outer: ", Module_top_level::run_outer(), "\n";
28             1                               print "run_begin: ", Module_top_level::run_begin(), "\n";


