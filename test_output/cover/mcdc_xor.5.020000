13                                             sub xor_decision {
14             4                           4     my ($p, $q) = @_;
15             4           100    100            return ($p xor $q);
16                                             }
17                                             
18                                             sub main {
19                                               # Calls are pushed into @r so each decision is exercised in non-void
20                                               # context; MC/DC for a void-context boolean has no result to analyse.
21             1                           1     my @r;
22                                             
23                                               # xor does not short-circuit, so the truth table has all four rows.
24                                               # MC/DC is satisfied with any three rows; observing all four also gives
25                                               # 100% expression coverage.
26             1                                 push @r, xor_decision(0, 0);
27             1                                 push @r, xor_decision(0, 1);
28             1                                 push @r, xor_decision(1, 0);
29             1                                 push @r, xor_decision(1, 1);
30                                             }
31                                             
32             1                               main();


