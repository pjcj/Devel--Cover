14                                             
15                                             # A sub that lexically encloses a my sub compiles with an introcv/clonecv
16                                             # prologue, which check_file and sub_info must step past or the enclosing
17                                             # sub is dropped from coverage entirely along with its body
18                                             
19                                             sub named_enc {
20             1                           1     my sub inner { my $x = shift; $x + 5 }
               1                               
21             1                           1     inner(shift)
22                                             }
23                                             
24                                             my $anon_enc = sub {
25             1                           1     my sub inner { my $x = shift; $x + 7 }
               1                               
26             1                           1     inner(shift)
27             1                               };
28                                             
29                                             sub nested_enc {
30                                               my sub mid {
31             1                           1       my sub deep { my $x = shift; $x + 9 }
               1                               
32             1                           1       deep(shift)
33                                               }
34             1                           1     mid(shift)
35                                             }
36                                             
37             1                           1   sub plain { my $x = shift; $x + 1 }
               1                               
38                                             
39             1                           1   sub run_anon { $anon_enc->(shift) }
40                                             
41             1                               1;


