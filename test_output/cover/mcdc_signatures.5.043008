8                                              # https://pjcj.net
9                                              
10                                             # Subroutine signatures (introduced experimentally in 5.20.0) compile to
11                                             # extra logops in the optree prologue for argument-count handling.  This
12                                             # fixture exercises MC/DC through subs declared with signatures so the
13                                             # per-CV walker is exercised against an optree that mixes signature
14                                             # logops with user logops.  The walker must isolate the two: signature
15                                             # ops are their own roots, and the user's decision metadata (root,
16                                             # width, column indices) must not be perturbed.
17                                             
18             1                           1   use 5.20.0;
               1                               
19             1                           1   use warnings;
               1                               
               1                               
20             1                           1   use feature qw( signatures );
               1                               
               1                               
21             1                           1   no warnings qw( experimental::signatures );
               1                               
               1                               
22                                             
23             3    100                    3   sub and_decision ($p, $q)         { $p && $q }
24             3    100                    3   sub or_decision  ($p, $q)         { $p         || $q }
25    ***      4    100    100   * 25      4   sub nested       ($a, $b, $c, $d) { ($a && $b) || ($c && $d) }
                           100                 
26                                             
27                                             sub main {
28             1                           1     my @r;
29                                             
30                                               # 2-input && hits all three short-circuit rows.
31             1                                 push @r, and_decision(1, 1);
32             1                                 push @r, and_decision(1, 0);
33             1                                 push @r, and_decision(0, 1);
34                                             
35                                               # 2-input || hits all three short-circuit rows.
36             1                                 push @r, or_decision(1, 0);
37             1                                 push @r, or_decision(0, 1);
38             1                                 push @r, or_decision(0, 0);
39                                             
40                                               # Mixed-precedence ($a && $b) || ($c && $d).  The statement-level outer ||
41                                               # is recorded as a branch but its decision structure is kept, so MC/DC
42                                               # measures the unified four-condition decision.  Called for its value, the
43                                               # decision's input vectors are observed, so MC/DC is proven (these four calls
44                                               # achieve it partially).  The per-CV walk stays clear of signature ops.
45             1                                 push @r, nested(1, 1, 0, 0);
46             1                                 push @r, nested(1, 0, 1, 1);
47             1                                 push @r, nested(0, 0, 1, 0);
48             1                                 push @r, nested(0, 0, 0, 0);
49                                             }
50                                             
51             1                               main();


