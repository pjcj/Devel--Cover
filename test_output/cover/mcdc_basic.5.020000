                           100                 
41                                             }
42                                             
43                                             sub main {
44                                               # Calls are pushed into @r so each decision is exercised in non-void
45                                               # context.  In void context the runtime collapses the right operand's
46                                               # truth value into the short-circuit count, leaving MC/DC nothing to
47                                               # analyse for the right atomic.
48             1                           1     my @r;
49                                             
50                                               # 2-input && hits all three short-circuit rows; MC/DC satisfied.
51             1                                 push @r, and_decision(1, 1);
52             1                                 push @r, and_decision(1, 0);
53             1                                 push @r, and_decision(0, 1);
54                                             
55                                               # 2-input || hits two of the three short-circuit rows; the (F,T)
56                                               # row is omitted, so the right atomic has no independence pair.
57             1                                 push @r, or_decision(1, 0);
58             1                                 push @r, or_decision(0, 0);
59                                             
60                                               # 3-input chained && hits all four short-circuit rows; the $p pair
61                                               # matches (F,X,X) against (T,T,T), exercising X compatibility
62                                               # across two columns at once.
63             1                                 push @r, chained_and(1, 1, 1);
64             1                                 push @r, chained_and(1, 1, 0);
65             1                                 push @r, chained_and(1, 0, 0);
66             1                                 push @r, chained_and(0, 0, 0);
67                                             
68                                               # 3-input chained || hits all four short-circuit rows.
69             1                                 push @r, chained_or(1, 0, 0);
70             1                                 push @r, chained_or(0, 1, 0);
71             1                                 push @r, chained_or(0, 0, 1);
72             1                                 push @r, chained_or(0, 0, 0);
73                                             
74                                               # Leading negation: exercises GH-446 address-based child linking
75                                               # so the underlying atomic is $p, not the negated value.
76             1                                 push @r, negated_and(0, 1);
77             1                                 push @r, negated_and(0, 0);
78             1                                 push @r, negated_and(1, 0);
79                                             
80                                               # Mixed-precedence (A && B) || C - the worked example from
81                                               # docs/technical/mcdc.md.
82             1                                 push @r, nested(1, 1, 0);
83             1                                 push @r, nested(1, 0, 0);
84             1                                 push @r, nested(0, 0, 1);
85             1                                 push @r, nested(1, 0, 1);
86             1                                 push @r, nested(0, 0, 0);
87                                             }
88                                             
