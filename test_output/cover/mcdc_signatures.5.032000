1                                              #!/usr/bin/perl
2                                              
3                                              # Copyright 2026, Paul Johnson (paul@pjcj.net)
4                                              
5                                              # This software is free.  It is licensed under the same terms as Perl itself.
6                                              
7                                              # The latest version of this software should be available from my homepage:
8                                              # https://pjcj.net
9                                              
10                                             # Subroutine signatures (introduced experimentally in 5.20.0) compile to
11                                             # extra logops in the optree prologue for argument-count handling.  This
12                                             # fixture exercises MC/DC through subs declared with signatures so the
13                                             # per-CV walker is exercised against an optree that mixes signature
14                                             # logops with user logops.  The walker must isolate the two: signature
15                                             # ops are their own roots, and the user's decision metadata (root,
16                                             # width, column indices) must not be perturbed.
17                                             
18             1                           1   use 5.20.0;
               1                               
19             1                           1   use warnings;
               1                               
               1                               
20             1                           1   use feature qw( signatures );
               1                               
               1                               
21             1                           1   no warnings qw( experimental::signatures );
               1                               
               1                               
22                                             
23             3    100                    3   sub and_decision ($p, $q)         { $p && $q }
24             3    100                    3   sub or_decision  ($p, $q)         { $p         || $q }
25    ***      4    100    100   * 25      4   sub nested       ($a, $b, $c, $d) { ($a && $b) || ($c && $d) }
                           100                 
                           100                 
26                                             
27             4           100    100      4   sub default_or  ($p, $q, $r = $p || $q) { $r }
               4                               
28             4           100    100      4   sub default_and ($p, $q, $r = $p && $q) { $r }
               4                               
29                                             
30                                             sub main {
31             1                           1     my @r;
32                                             
33                                               # 2-input && hits all three short-circuit rows.
34             1                                 push @r, and_decision(1, 1);
35             1                                 push @r, and_decision(1, 0);
36             1                                 push @r, and_decision(0, 1);
37                                             
38                                               # 2-input || hits all three short-circuit rows.
39             1                                 push @r, or_decision(1, 0);
40             1                                 push @r, or_decision(0, 1);
41             1                                 push @r, or_decision(0, 0);
42                                             
43                                               # Mixed-precedence ($a && $b) || ($c && $d).  The statement-level outer ||
44                                               # joins two compound operands, so it is recorded as a condition (alongside
45                                               # the branch) and MC/DC measures the unified four-condition decision.  Called
46                                               # for its value, the decision's input vectors are observed, so MC/DC is proven
47                                               # (these four calls achieve it partially).  The per-CV walk stays clear of
48                                               # signature ops.
49             1                                 push @r, nested(1, 1, 0, 0);
50             1                                 push @r, nested(1, 0, 1, 1);
51             1                                 push @r, nested(0, 0, 1, 0);
52             1                                 push @r, nested(0, 0, 0, 0);
53                                             
54                                               # A logop in a signature default expression is a user decision, measured
55                                               # and proven like any other despite sitting in the signature prologue
56                                               # among the argument-count logops.  The two-argument calls hit every row
57                                               # of each default; the three-argument calls skip the default entirely.
58             1                                 push @r, default_or(1, 0);
59             1                                 push @r, default_or(0, 1);
60             1                                 push @r, default_or(0, 0);
61             1                                 push @r, default_or(0, 0, 1);
62             1                                 push @r, default_and(1, 1);
63             1                                 push @r, default_and(1, 0);
64             1                                 push @r, default_and(0, 1);
65             1                                 push @r, default_and(0, 0, 1);
66                                             }
67                                             
68             1                               main();


